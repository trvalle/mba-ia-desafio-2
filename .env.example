# LangSmith Configuration
# Get your API key from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=prompt-optimization-challenge
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Your LangSmith username (for pushing prompts)
# Para descobrir seu username: publique qualquer prompt no LangSmith Hub, 
# depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
LANGSMITH_USERNAME=your_username_here
USERNAME_LANGSMITH_HUB=your_username_here

# LLM Provider Configuration - Choose one (OpenAI or Google)

# Option A: OpenAI (Recommended for this challenge)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EVAL_MODEL=gpt-4o-mini

# Option B: Google Gemini (Free Tier - Limited quota)
# Get API key from: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_google_api_key_here
# LLM_PROVIDER=google
# LLM_MODEL=gemini-3-flash-preview
# EVAL_MODEL=gemini-3-flash-preview